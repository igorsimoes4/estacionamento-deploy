DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=estacionamento
DB_USERNAME=root
DB_PASSWORD=

LOG_CHANNEL=stack
LOG_LEVEL=debug
AUDIT_ENABLED=true
AUDIT_CHANNEL=audit
AUDIT_LOG_LEVEL=info
AUDIT_LOG_DAYS=30
AUDIT_LOG_HTTP_REQUESTS=true
AUDIT_LOG_MODEL_EVENTS=true

BROADCAST_DRIVER=pusher
PUSHER_APP_ID=your_app_id
PUSHER_APP_KEY=your_app_key
PUSHER_APP_SECRET=your_app_secret
PUSHER_APP_CLUSTER=mt1
LARAVEL_WEBSOCKETS_PORT=6001 
